# ============================================================
# .env.example — AS Sierra Systems
# ============================================================
# Plantilla de variables de entorno para la base de datos MySQL.
# Duplica este archivo como '.env' en este mismo directorio
# y configura tus credenciales para trabajar de manera local.
# ============================================================

# --- Conexión mediante URI única (Recomendada para Railway / Render) ---
# MYSQL_URL=mysql://root:password@localhost:3306/sierra_systems

# --- O bien, Conexión mediante Host Individual (Recomendada para local) ---
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=tu_contraseña_aqui
MYSQLDATABASE=sierra_systems

# --- Puerto de ejecución del servidor Express ---
PORT=3000
